<?xml version="1.0" encoding="UTF-8"?>
<server description="JAX-RS 2.1 Client Thread Leak Test Server">

    <featureManager>
        <feature>jaxrs-2.1</feature>
        <feature>servlet-4.0</feature>
        <feature>mpMetrics-3.0</feature>
        <feature>cdi-2.0</feature>
    </featureManager>

    <httpEndpoint id="defaultHttpEndpoint"
                  httpPort="${bvt.prop.HTTP_default}"
                  httpsPort="${bvt.prop.HTTP_default.secure}" />

    <javaPermission className="java.net.SocketPermission" name="*" actions="connect,resolve,accept,listen"/>
    <javaPermission className="java.util.PropertyPermission" name="*" actions="read,write"/>
    <javaPermission className="java.lang.RuntimePermission" name="*"/>
    <javaPermission className="java.io.FilePermission" name="*" actions="read,write,delete"/>
    <javaPermission className="java.lang.reflect.ReflectPermission" name="*"/>
    <javaPermission className="java.security.AllPermission" name="*" actions="*"/>

    <mpMetrics authentication="false" />
   
    <logging traceSpecification="*=info:org.apache.cxf.io.DelayedCachedOutputStreamCleaner=all:com.ibm.ws.jaxrs21.client.fat.test.*=all" />

</server>
