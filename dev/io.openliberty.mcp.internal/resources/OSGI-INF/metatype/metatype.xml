<?xml version="1.0" encoding="UTF-8"?>
<metatype:MetaData xmlns:metatype="http://www.osgi.org/xmlns/metatype/v1.1.0"
                   xmlns:ibm="http://www.ibm.com/xmlns/appservers/osgi/metatype/v1.0.0"
                   xmlns:ibmui="http://www.ibm.com/xmlns/appservers/osgi/metatype/ui/v1.0.0"
                   localization="OSGI-INF/l10n/metatype">

<Designate factoryPid="io.openliberty.mcp.internal.config.McpConfigurationComponent">
    <Object ocdref="io.openliberty.mcp.internal.config.McpConfigurationComponent" />
</Designate>

<OCD name="%mcpServer.name" description="%mcpServer.description"
     id="io.openliberty.mcp.internal.config.McpConfigurationComponent"
     ibm:childAlias="mcpServer"
     ibm:parentPid="com.ibm.ws.app.manager"
     ibm:supportHiddenExtensions="true">
    <AD name="%stateless.name"
        description="%stateless.description"
    	id="stateless"
    	required="false"
    	type="Boolean"
    	default="false"/>
    <AD name="%moduleName.name"
	    description="%moduleName.description"
	    id="moduleName"
	    required="false"
	    type="String"/>
	<AD name="%path.name"
	    description="%path.description"
	    id="path"
	    required="false"
	    type="String"
	    default="/mcp"/>
	<AD name="%sessionTimeout.name"
	    description="%sessionTimeout.description"
	    id="sessionTimeout"
	    required="false"
	    type="String"
	    ibm:type="duration(s)"
	    default="600s"/>
    <AD name="%asyncTimeout.name"
        description="%asyncTimeout.description"
        id="asyncTimeout"
        required="false"
        type="String"
        ibm:type="duration(s)"
        default="30s"/>
	<AD name="%info.name"
	    description="%info.description"
	    id="info"
	    ibm:type="pid"
	    ibm:reference="io.openliberty.mcp.internal.config.info"
	    ibm:flat="true"
	    cardinality="1"
	    required="false"
	    type="String"/>
</OCD>

<Designate factoryPid="io.openliberty.mcp.internal.config.info">
    <Object ocdref="io.openliberty.mcp.internal.config.info"></Object>
</Designate>

<OCD name="%info.name" description="%info.description"
     id="io.openliberty.mcp.internal.config.info">
    <AD id="name"
        name="%info.name.name"
        description="%info.name.description"
        required="false"
        type="String"
        default="mcp-server"/>
    <AD id="title"
        name="%info.title.name"
        description="%info.title.description"
        required="false"
        type="String"/>
    <AD id="version"
        name="%info.version.name"
        description="%info.version.description"
        required="false"
        type="String"
        default="1.0.0"/>
    <AD id="description"
        name="%info.description.name"
        description="%info.description.description"
        required="false"
        type="String"/>
</OCD>

</metatype:MetaData>
