-include= ~../cnf/resources/bnd/bundle.props

# Include all bucket-specific .bnd files
-sub: *.bnd

bVersion=1.0

src: \
    fat/src

fat.project: true

# Tested features - enable database rotation
tested.features: databaserotation

# Common dependencies - reference the .common project
-buildpath: \
    com.ibm.ws.jpa_testframework;version=latest,\
    com.ibm.ws.jpa.tests.spec10.callback_fat.common;version=latest,\
    io.openliberty.org.testcontainers;version=latest
