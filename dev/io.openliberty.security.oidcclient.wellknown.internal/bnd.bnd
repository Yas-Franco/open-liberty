-include= ~../cnf/resources/bnd/bundle.props

bVersion=1.0

-sub: *.bnd

Web-ContextPath: /.well-known/oauth-protected-resource

Import-Package: \
  io.openliberty.security.oidcclient.wellknown.common, \
  javax.servlet, \
  javax.servlet.http, \
  *

-buildpath: \
  com.ibm.websphere.javaee.servlet.3.0;version=latest, \
  com.ibm.websphere.org.osgi.core;version=latest, \
  com.ibm.wsspi.org.osgi.service.component.annotations;version=latest, \
  com.ibm.ws.security.openidconnect.client;version=latest, \
  io.openliberty.security.oidcclientcore.internal;version=latest

-testpath: \
  ../build.sharedResources/lib/junit/old/junit.jar;version=file, \
  com.ibm.ws.junit.extensions;version=latest, \
  com.ibm.ws.logging;version=latest