<server description="MCP Server with Multiple Apps - Partial and Custom ServerInfo">

  <featureManager>
    <feature>servlet-6.0</feature>
    <feature>cdi-4.0</feature>
    <feature>mcpServer-1.0</feature>
  </featureManager>
 
  
	<application location="partialServerInfoTest.war">
	    <mcpServer>
	        <!-- Only provide name, leave other fields empty/unset to test null handling -->
	        <info name="partial-server" />
	    </mcpServer>
	</application>

	<application location="fullyCustomServerInfoTest.war">
	    <mcpServer>
	        <!-- Updated values to test dynamic configuration -->
	        <info name="updated-server-name"
	              title="Updated Server Title"
	              version="3.0.0"
	              description="Updated server description" />
	    </mcpServer>
	</application>

  <include location="../fatTestPorts.xml" />
  
</server>