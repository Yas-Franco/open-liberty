-include= ~../cnf/resources/bnd/bundle.props

bVersion=1.0

Web-ContextPath: /.well-known/oauth-protected-resource

Private-Package: \
  io.openliberty.security.oidcclient.wellknown.internal.jakarta

Import-Package: \
  jakarta.servlet, \
  jakarta.servlet.http, \
  *

-dsannotations: \
  io.openliberty.security.oidcclient.wellknown.internal.jakarta.OAuthProtectedResourceMetadataServletService

-buildpath: \
  com.ibm.websphere.appserver.servlet-5.0;version=latest, \
  com.ibm.websphere.org.osgi.core;version=latest, \
  com.ibm.wsspi.org.osgi.service.component.annotations;version=latest, \
  io.openliberty.security.oidcclientcore.internal.jakarta;version=latest

-testpath: \
  ../build.sharedResources/lib/junit/old/junit.jar;version=file, \
  com.ibm.ws.junit.extensions;version=latest, \
  org.hamcrest:hamcrest-all;version=1.3, \
  org.mockito:mockito-core;version=4.11.0, \
  org.mockito:mockito-inline;version=4.11.0, \
  net.bytebuddy:byte-buddy;version=1.17.8, \
  net.bytebuddy:byte-buddy-agent;version=1.17.8