-include= ~../cnf/resources/bnd/bundle.props
bVersion=1.0

Bundle-Name: Model Context Protocol Microprofile Metrics
Bundle-SymbolicName: io.openliberty.mcp.internal.mpmetrics
Bundle-Description: Open Liberty Model Context Protocol Microprofile Metrics, version ${bVersion}

javac.source: 17
javac.target: 17

WS-TraceGroup: MCP

Import-Package: \
	jakarta.enterprise.inject; version="[4.0,5)",\
	jakarta.enterprise.util; version="[4.0,5)",\
	jakarta.annotation; version="[2.1,4)",\
	jakarta.interceptor; version="[2.1,3)",\
	jakarta.enterprise.context.spi; version="[4.0,5)",\
	org.eclipse.microprofile.config; version="[3.0,4)",\
	*
	

-dsannotations-inherit: true
-dsannotations: \
	io.openliberty.mcp.internal.mpmetrics.MPMetricsMcpMetricsAdapterImpl
	
Private-Package: \
	io.openliberty.mcp.internal.mpmetrics.*

-buildpath: \
	com.ibm.websphere.org.osgi.core;version=latest,\
	com.ibm.websphere.org.osgi.service.component;version=latest,\
	com.ibm.wsspi.org.osgi.service.component.annotations;version=latest,\
	com.ibm.ws.logging;version=latest,\
	com.ibm.ws.container.service;version=latest,\
	com.ibm.ws.kernel.service;version=latest,\
	io.openliberty.mcp.internal;version=latest,\
	io.openliberty.mcp.internal.monitor;version=latest,\
	io.openliberty.microprofile.metrics.5.0.internal;version=latest,\
	io.openliberty.org.eclipse.microprofile.metrics.5.0;version=latest,\
	com.ibm.ws.org.osgi.annotation.versioning;version=latest,\