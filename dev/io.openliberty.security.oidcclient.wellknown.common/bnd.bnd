-include= ~../cnf/resources/bnd/bundle.props

bVersion=1.0

Bundle-Name: Open Liberty OIDC Client Well-Known Common
Bundle-SymbolicName: io.openliberty.security.oidcclient.wellknown.common
Bundle-Description: Shared code for OIDC client well-known endpoint support, version=${bVersion}

Export-Package: \
  io.openliberty.security.oidcclient.wellknown.common;version=${bVersion}
Import-Package: \
  *

-testpath: \
  ../build.sharedResources/lib/junit/old/junit.jar;version=file, \
  com.ibm.ws.junit.extensions;version=latest, \
  com.ibm.ws.logging;version=latest