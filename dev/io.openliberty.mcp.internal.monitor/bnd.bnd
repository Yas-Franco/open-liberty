-include= ~../cnf/resources/bnd/bundle.props
bVersion=1.0

Bundle-Name: Model Context Protocol Monitor
Bundle-SymbolicName: io.openliberty.mcp.internal.monitor
Bundle-Description: Open Liberty Model Context Protocol Monitor, version ${bVersion}

javac.source: 17
javac.target: 17

WS-TraceGroup: MCP

Import-Package: \
	*

Export-Package: \
	io.openliberty.mcp.internal.monitor.metrics

Private-Package: \
	io.openliberty.mcp.monitor,\
	io.openliberty.mcp.internal.monitor

-dsannotations: \
  io.openliberty.mcp.internal.monitor.metrics.MetricsManager,\
  io.openliberty.mcp.internal.monitor.McpMonitorAppStateListener

Liberty-Monitoring-Components: io.openliberty.mcp.internal.monitor.McpStatsMonitorImpl

-buildpath: \
	io.openliberty.jakarta.servlet.6.0;version=latest,\
	com.ibm.ws.monitor;version=latest,\
	com.ibm.websphere.org.osgi.core;version=latest,\
	com.ibm.websphere.org.osgi.service.component;version=latest,\
	com.ibm.wsspi.org.osgi.service.component.annotations;version=latest,\
	com.ibm.ws.org.osgi.annotation.versioning;version=latest,\
	com.ibm.ws.logging.core;version=latest,\
	com.ibm.ws.kernel.service;version=latest,\
	com.ibm.ws.container.service;version=latest,\
	io.openliberty.mcp;version=latest,\
	io.openliberty.mcp.internal;version=latest
-testpath: com.ibm.ws.componenttest.2.0